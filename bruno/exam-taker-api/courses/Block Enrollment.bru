meta {
  name: Block Enrollment
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/enrollments/:id/block
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:path {
  id:
}

docs {
  Teacher only, requires an active tenant. `id` is the enrollment id
  (course_enrollments row), not the student's user id.
}
