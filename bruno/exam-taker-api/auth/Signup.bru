meta {
  name: Signup
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "username": "testteacher",
    "phone": "01730238192",
    "role": "teacher",
    "password": "password123",
    "passwordConfirmation": "password123"
  }
}

script:post-response {
  if (res.body.token) {
    bru.setVar("token", res.body.token);
  }
}

docs {
  Creates a new account (ADR-0065 one-screen signup) and stores the returned
  bearer token into a runtime `token` variable via bru.setVar (ADR-0064) —
  not written to disk — so subsequent requests in this environment are
  authenticated automatically.
  
  phone must match BD local mobile format: 01[3-9]XXXXXXXX.
  role can be `student` or `teacher`; teacher signup also creates the initial
  tenant and owner membership.
  Change the username/phone before re-running — signup fails on
  duplicates.
}
